[Unit]
Description=Training App Resolve Pending Items
After=network.target

[Service]
Type=oneshot
WorkingDirectory=/home/pablo/ProyectoGarmin
EnvironmentFile=/home/pablo/ProyectoGarmin/.env
ExecStart=/home/pablo/ProyectoGarmin/.venv/bin/python -m app.jobs.resolve_pending_items
StandardOutput=journal
StandardError=journal
